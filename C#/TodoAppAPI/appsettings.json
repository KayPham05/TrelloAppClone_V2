{
  "ConnectionStrings": {
    "TodosDatabase": "Server=YOUR_SERVER;Database=TodosDB;Trusted_Connection=true;TrustServerCertificate=True"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Key": "YOUR_JWT_SECRET_KEY_HERE_MIN_32_CHARS",
    "Issuer": "TodoAppAPI",
    "Audience": "TodoAppClient",
    "AccessTokenExpiryMinutes": 15
  },
  "CloudinarySettings": {
    "CloudName": "YOUR_CLOUDINARY_NAME",
    "ApiKey": "YOUR_CLOUDINARY_API_KEY",
    "ApiSecret": "YOUR_CLOUDINARY_API_SECRET"
  },
  "GeminiSettings": {
    "ApiKey": "",
    "Model": "gemini-3.5-flash",
    "TimeoutSeconds": 30,
    "CacheMinutes": 5,
    "MaxRisks": 5,
    "MaxSuggestions": 5
  },
  "AllowedHosts": "*"
}
